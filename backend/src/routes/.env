# Copy this file to .env and fill in all values before running

# PostgreSQL — password for the database
POSTGRES_PASSWORD=replace-with-strong-password

# JWT signing secret — use a long random string
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-long-random-secret

# MinIO object storage credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-password
